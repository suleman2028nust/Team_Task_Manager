# --- Server Configuration ---
PORT=8080
NODE_ENV=development

# --- Database Configuration (Neon PostgreSQL) ---
# Format: postgres://<user>:<password>@<host>/<database>?sslmode=require
DATABASE_URL=postgres://your_neon_user:your_neon_password@ep-cool-shadow.us-central1.aws.neon.tech/neondb?sslmode=require

# --- Security & Session Configuration ---
# Provide a strong, unique secret key for cookie/session encryption
SESSION_SECRET=your_super_secret_session_key_change_me_in_production
